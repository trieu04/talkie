# Talkie — Production Environment
# Copy to .env.prod and fill in all values before deploying.

# ── Domain ──────────────────────────────────────────────
DOMAIN=talkie.example.com
ACME_EMAIL=admin@example.com
VERSION=latest

# ── Postgres ────────────────────────────────────────────
POSTGRES_DB=talkie
POSTGRES_USER=talkie
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── MinIO / S3 ──────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET_NAME=talkie-audio

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS_LONG
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ── External APIs ───────────────────────────────────────
GOOGLE_TRANSLATE_API_KEY=
OPENAI_API_KEY=

# ── Worker ──────────────────────────────────────────────
WORKER_TIMEOUT_SECONDS=30
WORKER_MAX_RETRIES=3

# ── App ─────────────────────────────────────────────────
LOG_LEVEL=WARNING
VITE_API_URL=/api
VITE_WS_URL=/ws

# ── Traefik (optional) ─────────────────────────────────
# htpasswd -nB admin → paste here
TRAEFIK_AUTH=
